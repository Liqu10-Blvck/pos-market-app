rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Retrieve user data from the usuarios collection
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user exists, is active and has admin role
    function isAdmin() {
      return isAuthenticated() && 
        getUserData().role == 'admin' && 
        getUserData().activo == true;
    }

    // Helper function to check if user is active (admin or cashier)
    function isActive() {
      return isAuthenticated() && 
        getUserData().activo == true;
    }
    
    // Productos: Read for active users, write only for admin
    match /productos/{productoId} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin();
    }
    
    // Ventas: Read for active users, create for active users, NEVER update or delete
    match /ventas/{ventaId} {
      allow read: if isActive();
      allow create: if isActive() && 
        request.resource.data.keys().hasAll(['items', 'total', 'metodo_pago', 'sesion_id', 'fecha']) &&
        request.resource.data.total > 0 &&
        request.resource.data.items.size() > 0;
      allow update, delete: if false;
    }
    
    // Clientes: Read, create and update for active users, delete only for admin
    match /clientes/{clienteId} {
      allow read, create, update: if isActive();
      allow delete: if isAdmin();
    }
    
    // Sesiones de Caja: Control for active users, no deletion allowed
    match /sesiones_caja/{sesionId} {
      allow read, create, update: if isActive();
      allow delete: if false;
    }
    
    // Costos Diarios: Read for active users, write only for admin
    match /costos_diarios/{costoId} {
      allow read: if isActive();
      allow create, update, delete: if isAdmin();
    }
    
    // Cuentas contables: Read for active users, write only for admin
    match /cuentas/{cuentaCodigo} {
      allow read: if isActive();
      allow write: if isAdmin();
    }
    
    // Asientos contables: Read and create for active users, no updates/deletes
    match /asientos/{asientoId} {
      allow read, create: if isActive();
      allow update, delete: if false;
    }
    
    // Facturas de compras (compras): Read for active users, create only for admin, no updates/deletes
    match /compras/{compraId} {
      allow read: if isActive();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    
    // Consultas e historial IA: Read/write for active users
    match /consultas_ia/{consultaId} {
      allow read, write: if isActive();
    }
    
    // Metadata: Read for active users, write only for admin
    match /metadata/{documentId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // Usuarios: Read for self or admin
    match /usuarios/{usuarioId} {
      allow read: if isAuthenticated() && (request.auth.uid == usuarioId || isAdmin());
      // Allows new sign up to create their own record on registration (limited to inactive cashier), or admin to create accounts, or owner as active admin
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == usuarioId && (
          (request.resource.data.role == 'cashier' && request.resource.data.activo == false) ||
          (request.auth.token.email == 'nicolasmacortesgallardo@gmail.com' && request.resource.data.role == 'admin' && request.resource.data.activo == true)
        ))
      );
      // Allows self-update (excluding role/active fields) or total update by admin
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == usuarioId && 
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'activo']))
        )
      );
      allow delete: if isAdmin();
    }

    // Metas Financieras: Read for active users, write only for admin
    match /metas_financieras/{metaId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // Gastos Programados: Read for active users, write only for admin
    match /gastos_programados/{gastoId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // Distribución de Fondos: Read for active users, write only for admin
    match /distribucion_fondos/{distribucionId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // Pedidos: Read and write validation for active users
    match /pedidos/{pedidoId} {
      allow read: if isActive();
      allow create: if isActive() &&
        request.resource.data.keys().hasAll(['items', 'total', 'estado', 'estado_pago', 'fecha']) &&
        request.resource.data.total >= 0 &&
        request.resource.data.items.size() > 0;
      allow update: if isActive() &&
        request.resource.data.total >= 0;
      allow delete: if isAdmin();
    }

    // Registro Precios Mayoristas: Read for active users, create only for admin, update/delete disabled
    match /registro_precios_mayoristas/{registroId} {
      allow read: if isActive();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
