rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función helper para verificar autenticación
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Productos: Lectura y escritura para autenticados
    match /productos/{productoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Ventas: Crear para autenticados, NUNCA editar o borrar
    match /ventas/{ventaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['items', 'total', 'metodo_pago', 'sesion_id', 'fecha']) &&
        request.resource.data.total > 0 &&
        request.resource.data.items.size() > 0;
      // PROHIBIDO editar o eliminar ventas
      allow update, delete: if false;
    }
    
    // Clientes: Lectura y creación para autenticados
    match /clientes/{clienteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
    
    // Sesiones de Caja: Control estricto
    match /sesiones_caja/{sesionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.cerrada == false &&
        request.resource.data.monto_inicial >= 0;
      allow update: if isAuthenticated();
      allow delete: if false; // Nunca eliminar sesiones
    }
    
    // Costos Diarios: Lectura y escritura para autenticados
    match /costos_diarios/{costoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }
    
    // Metadata: Lectura y escritura para autenticados
    match /metadata/{documentId} {
      allow read, write: if isAuthenticated();
    }
  }
}
